# Copier en .env pour personnaliser (optionnel sauf pour l'IA).
# AUCUNE clé exchange n'est requise pour le paper trading (données publiques).

# Exchange ccxt par défaut pour la collecte crypto (modifiable aussi à chaud
# depuis la page de configuration). Les actifs/timeframes sont définis par
# instrument (voir INSTRUMENTS plus bas).
EXCHANGE=binance

INITIAL_BALANCE=1000
FEE_RATE=0.001

COLLECTION_INTERVAL=60
TRADING_INTERVAL=60

# Stratégie
RSI_PERIOD=14
MA_SHORT=20
MA_LONG=50
BUY_THRESHOLD=0.35
SELL_THRESHOLD=-0.35

# --- Intelligence artificielle (Gemini) ---
# Clé API : https://aistudio.google.com/apikey  (commence en général par "AIza")
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_INTERVAL=1800       # fréquence d'analyse IA par actif (secondes)
AI_WEIGHT=0.5          # poids de l'avis IA dans le score final [0..1]

# --- News ---
NEWS_ENABLED=true
NEWS_RSS_URL=https://cointelegraph.com/rss   # flux par défaut (crypto) ; les autres classes ont leurs propres flux

# --- Machine Learning ---
ML_ENABLED=true
ML_MODEL=mlp                # "mlp" (réseau de neurones) ou "logreg" (léger)
ML_HORIZON=10               # label : hausse/baisse dans N bougies
ML_INTERVAL=1800            # ré-entraînement / inférence (s)
ML_WEIGHT=0.0               # poids de la proba ML dans la décision [0..1] (0 = ignoré)
# Sur Raspberry Pi : laisser FALSE (entraîner sur PC, copier data/models/*.json sur le Pi)
ML_TRAIN_ENABLED=true

# --- Raspberry Pi Zero ---
# 1) Construire l'image avec les deps allégées (sans scikit-learn) :
#       docker compose build --build-arg REQ=requirements-pi.txt
# 2) Lancer avec : ML_TRAIN_ENABLED=false  (inférence ML en numpy pur)
# 3) Entraîner les modèles sur PC puis copier data/models/<actif>.json sur le Pi.

# --- Instruments suivis (optionnel) ---
# Par défaut : BTC (crypto), Or, Apple (action), EUR/USD (forex).
# Pour personnaliser, fournir un JSON. Exemple (une seule ligne) :
# INSTRUMENTS=[{"id":"BTC","name":"Bitcoin","asset_class":"crypto","provider":"ccxt","symbol":"BTC/USDT","timeframe":"1m","quote":"USDT"},{"id":"ETH","name":"Ethereum","asset_class":"crypto","provider":"ccxt","symbol":"ETH/USDT","timeframe":"1m","quote":"USDT"},{"id":"GOLD","name":"Or","asset_class":"commodity","provider":"yfinance","symbol":"GC=F","timeframe":"5m","quote":"USD"},{"id":"TSLA","name":"Tesla","asset_class":"stock","provider":"yfinance","symbol":"TSLA","timeframe":"5m","quote":"USD"}]

# --- Trading RÉEL uniquement (NE PAS remplir pour le paper trading) ---
# EXCHANGE_API_KEY=
# EXCHANGE_SECRET=
